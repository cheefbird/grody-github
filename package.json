{
  "name": "grody-github",
  "description": "Filter your Github workflows, and more!",
  "private": true,
  "version": "0.5.3",
  "type": "module",
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:edge": "wxt -b edge",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format",
    "format:fix": "biome format --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@tsconfig/svelte": "5.0.8",
    "@wxt-dev/module-svelte": "2.0.5",
    "happy-dom": "20.10.6",
    "svelte": "5.56.4",
    "svelte-check": "4.7.2",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wxt": "0.20.27"
  }
}
