{
  "name": "grody-github",
  "description": "Filter your Github workflows, and more!",
  "private": true,
  "version": "0.5.3",
  "type": "module",
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:edge": "wxt -b edge",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format",
    "format:fix": "biome format --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@tsconfig/svelte": "5.0.8",
    "@wxt-dev/module-svelte": "2.0.5",
    "happy-dom": "20.10.6",
    "svelte": "5.56.5",
    "svelte-check": "4.7.3",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wxt": "0.20.27"
  }
}
