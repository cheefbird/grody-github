{
  "name": "grody-github",
  "description": "Filter your Github workflows, and more!",
  "private": true,
  "version": "0.5.3",
  "type": "module",
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:edge": "wxt -b edge",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format",
    "format:fix": "biome format --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@tsconfig/svelte": "5.0.8",
    "@wxt-dev/module-svelte": "2.0.5",
    "happy-dom": "20.10.6",
    "svelte": "5.56.4",
    "svelte-check": "4.7.2",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wxt": "0.20.27"
  }
}
