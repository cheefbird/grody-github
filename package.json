{
  "name": "grody-github",
  "description": "Filter your Github workflows, and more!",
  "private": true,
  "version": "0.5.2",
  "type": "module",
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:edge": "wxt -b edge",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format",
    "format:fix": "biome format --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@tsconfig/svelte": "5.0.8",
    "@wxt-dev/module-svelte": "2.0.5",
    "happy-dom": "20.10.3",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "wxt": "0.20.26"
  }
}
