{
  "name": "grody-github",
  "description": "A less refined Github annoyance eliminator.",
  "private": true,
  "version": "0.4.2",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:edge": "wxt -b edge",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "format": "biome format",
    "format:fix": "biome format --fix",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@tsconfig/svelte": "5.0.8",
    "@wxt-dev/module-svelte": "2.0.5",
    "svelte": "5.55.0",
    "svelte-check": "4.4.5",
    "tslib": "2.8.1",
    "typescript": "6.0.2",
    "vitest": "4.1.2",
    "wxt": "0.20.20"
  }
}
