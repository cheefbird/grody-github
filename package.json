{
  "name": "grody-github",
  "description": "A less refined Github annoyance eliminator.",
  "private": true,
  "version": "0.3.3",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "format": "biome format",
    "lint": "biome lint",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@tsconfig/svelte": "^5.0.8",
    "@wxt-dev/module-svelte": "^2.0.4",
    "svelte": "^5.53.11",
    "svelte-check": "^4.4.5",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.18"
  }
}
