{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "schedule": [
    "after 6pm every weekday",
    "every weekend",
    "before 5am every weekday"
  ],
  "prConcurrentLimit": 3,
  "automerge": false,
  "major": {
    "automerge": false
  },
  "packageRules": [
    {
      "description": "Group extension framework packages (WXT + Svelte + bridge module share peer deps)",
      "matchPackageNames": [
        "wxt",
        "@wxt-dev/module-svelte",
        "svelte",
        "svelte-check",
        "@tsconfig/svelte"
      ],
      "groupName": "extension framework"
    }
  ]
}
